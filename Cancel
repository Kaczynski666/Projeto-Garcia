<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Projeto Garcia Internações | Resgate e Internação para Dependência Química</title>
<meta name="description" content="Referência em resgate e internação para dependência química e alcoólica. Amparo imediato, clínicas legalizadas e suporte 24h.">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Sora:wght@600;700;800&display=swap" rel="stylesheet">

<style>
  :root{
    --navy-950:#060f1f;
    --navy-900:#0b1f3a;
    --navy-800:#10284d;
    --navy-700:#163566;
    --navy-600:#1d4684;
    --silver-100:#f4f6f9;
    --silver-200:#e3e8ef;
    --silver-300:#c7cdd6;
    --blue-cta:#2f6fed;
    --blue-cta-hover:#2659c7;
    --wa:#25d366;
  }

  *{ margin:0; padding:0; box-sizing:border-box; }
  html{ scroll-behavior:smooth; }
  body{
    font-family:'Inter', sans-serif;
    color:var(--navy-900);
    background:#fff;
    -webkit-font-smoothing:antialiased;
  }
  h1,h2,.font-display{ font-family:'Sora', sans-serif; }
  img{ display:block; max-width:100%; }
  a{ text-decoration:none; color:inherit; }

  .container{ max-width:480px; margin:0 auto; padding:0 24px; }

  /* ===== HERO ===== */
  .hero{
    position:relative;
    overflow:hidden;
    background:linear-gradient(180deg, var(--navy-950) 0%, var(--navy-900) 45%, var(--navy-700) 100%);
    padding:32px 0 48px;
  }
  .hero::before{
    content:"";
    position:absolute; inset:0;
    background-image:radial-gradient(rgba(255,255,255,0.06) 1px, transparent 1px);
    background-size:14px 14px;
    opacity:0.4;
    pointer-events:none;
  }
  .hero-inner{ position:relative; z-index:1; }

  .logo-wrap{ display:flex; flex-direction:column; align-items:center; }
  .logo-circle{
    width:96px; height:96px;
    border-radius:50%;
    overflow:hidden;
    background:var(--navy-900);
    box-shadow:0 10px 30px rgba(0,0,0,0.4);
    border:2px solid rgba(199,205,214,0.7);
  }
  .logo-circle img{ width:100%; height:100%; object-fit:cover; }
  .brand-label{
    margin-top:12px;
    font-size:11px;
    letter-spacing:0.25em;
    text-transform:uppercase;
    color:var(--silver-300);
    font-weight:600;
  }

  .headline{
    margin-top:28px;
    text-align:center;
    font-size:26px;
    line-height:1.25;
    font-weight:800;
    color:#fff;
  }
  .headline .accent{ color:var(--silver-200); }

  .subheadline{
    margin-top:16px;
    text-align:center;
    font-size:15px;
    line-height:1.55;
    color:rgba(227,232,239,0.9);
  }

  .cta-wrap{
    margin-top:28px;
    display:flex;
    flex-direction:column;
    align-items:center;
    gap:12px;
  }

  @keyframes pulse-ring{
    0%   { box-shadow:0 0 0 0 rgba(47,111,237,0.55); }
    70%  { box-shadow:0 0 0 14px rgba(47,111,237,0); }
    100% { box-shadow:0 0 0 0 rgba(47,111,237,0); }
  }
  .btn-cta{
    width:100%;
    text-align:center;
    border-radius:9999px;
    background:var(--blue-cta);
    color:#fff;
    font-family:'Sora', sans-serif;
    font-weight:700;
    font-size:15px;
    letter-spacing:0.02em;
    padding:16px 20px;
    box-shadow:0 12px 24px rgba(15,40,90,0.4);
    border:1px solid rgba(255,255,255,0.1);
    animation:pulse-ring 2.2s ease-out infinite;
    transition:transform 0.15s ease, background 0.2s ease;
    cursor:pointer;
  }
  .btn-cta:hover{ background:var(--blue-cta-hover); }
  .btn-cta:active{ transform:scale(0.98); }

  .trust-line{
    display:flex; align-items:center; gap:6px;
    font-size:12px;
    color:rgba(199,205,214,0.8);
  }
  .dot{
    width:6px; height:6px; border-radius:50%;
    background:#34d399; display:inline-block;
  }

  /* ===== DIFERENCIAIS ===== */
  .section-diff{
    background:var(--silver-100);
    padding:48px 0;
  }
  .section-title{
    text-align:center;
    font-weight:700;
    font-size:20px;
    color:var(--navy-900);
  }

  .grid-cards{
    margin-top:28px;
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:14px;
  }
  .card{
    background:#fff;
    border-radius:16px;
    padding:16px;
    border:1px solid rgba(199,205,214,0.6);
    box-shadow:0 1px 2px rgba(0,0,0,0.04);
  }
  .icon-circle{
    width:40px; height:40px;
    border-radius:50%;
    background:var(--navy-900);
    display:flex; align-items:center; justify-content:center;
  }
  .icon-circle svg{ width:20px; height:20px; stroke:var(--silver-200); fill:none; stroke-width:1.8; }
  .card p{
    margin-top:12px;
    font-size:13.5px;
    font-weight:600;
    line-height:1.4;
    color:var(--navy-900);
  }

  /* ===== SIGILO / UNIDADES ===== */
  .section-trust{
    background:var(--navy-900);
    padding:48px 0;
    text-align:center;
  }
  .shield-icon{ width:32px; height:32px; margin:0 auto; stroke:var(--silver-300); fill:none; stroke-width:1.6; }
  .trust-title{
    margin-top:16px;
    color:#fff;
    font-weight:600;
    font-size:17px;
    line-height:1.4;
  }
  .trust-sub{
    margin-top:4px;
    color:rgba(199,205,214,0.9);
    font-size:15px;
  }

  .btn-secondary{
    margin-top:28px;
    display:inline-flex;
    width:100%;
    align-items:center;
    justify-content:center;
    border-radius:9999px;
    background:#fff;
    color:var(--navy-900);
    font-family:'Sora', sans-serif;
    font-weight:700;
    font-size:15px;
    padding:16px 0;
    box-shadow:0 8px 20px rgba(0,0,0,0.25);
    transition:transform 0.15s ease;
  }
  .btn-secondary:active{ transform:scale(0.98); }

  .btn-ghost{
    margin-top:16px;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap:6px;
    width:100%;
    padding:13px 0;
    border-radius:9999px;
    border:1px solid rgba(199,205,214,0.4);
    color:var(--silver-200);
    font-size:13.5px;
    font-weight:600;
    transition:background 0.2s ease, border-color 0.2s ease;
  }
  .btn-ghost:hover{ background:rgba(255,255,255,0.06); border-color:rgba(199,205,214,0.7); }
  .btn-ghost .arrow{ width:14px; height:14px; stroke:currentColor; fill:none; stroke-width:2; }

  /* ===== FOOTER ===== */
  footer{
    background:var(--navy-950);
    text-align:center;
    padding:20px 0;
  }
  footer p{
    font-size:11px;
    color:rgba(199,205,214,0.5);
  }

  /* ===== BOTÃO FLUTUANTE WHATSAPP ===== */
  @keyframes pulse-ring-wa{
    0%   { box-shadow:0 0 0 0 rgba(37,211,102,0.55); }
    70%  { box-shadow:0 0 0 12px rgba(37,211,102,0); }
    100% { box-shadow:0 0 0 0 rgba(37,211,102,0); }
  }
  .wa-float{
    position:fixed;
    bottom:20px; right:20px;
    z-index:999;
    width:58px; height:58px;
    border-radius:50%;
    background:var(--wa);
    display:flex; align-items:center; justify-content:center;
    box-shadow:0 12px 24px rgba(0,0,0,0.3);
    border:1px solid rgba(255,255,255,0.3);
    animation:pulse-ring-wa 2.2s ease-out infinite;
  }
  .wa-float svg{ width:30px; height:30px; fill:#fff; }

  @media (min-width:480px){
    .headline{ font-size:28px; }
  }
</style>
</head>

